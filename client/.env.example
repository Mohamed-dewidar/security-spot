# Copy to `.env` and adjust as needed:
#   cp .env.example .env
#
# Vite only exposes variables prefixed with VITE_ to client code.
# Restart `pnpm dev` after changing this file.

# API data source.
# - false (default): in-memory local implementation (`src/api/implementations/local.ts`).
#   No server required — use this for the frontend-only submission.
# - true: HTTP client (`src/api/implementations/http.ts`) targeting `/api/v1/*`.
#   Requires the Express API to be running (not included in this submission).
VITE_USE_API=false
