# Copy to `.env` and adjust as needed:
#   cp .env.example .env
#
# Vite only exposes variables prefixed with VITE_ to client code.
# Restart `pnpm dev` after changing this file.

# API data source.
#
# false (default) — in-memory local implementation (`src/api/implementations/local.ts`).
#   No server required. Use this for the frontend-only reviewer flow.
#
# true — HTTP client (`src/api/implementations/http.ts`) via `VITE_API_URL`.
#   Requires BOTH processes running:
#     1. `cd server && pnpm dev`  (Express on http://localhost:3001)
#     2. `cd client && pnpm dev`  (Vite on http://localhost:5173)
#   Health check: `curl http://localhost:3001/api/v1/health`
VITE_USE_API=false

# Full API base URL (required when VITE_USE_API=true). Include `/api/v1`.
VITE_API_URL=http://localhost:3001/api/v1
#
# Tests use `.env.test` (VITE_USE_API=false) so Vitest stays on the local API.
